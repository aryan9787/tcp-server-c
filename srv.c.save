/* srv.c */
#include <netinet/in.h>
#include <stdio.h>
#include <sys/socket.h>
#include <arpa/inet.h>
#include <sys/types.h>
#include <unistd.h>
#include <stdlib.h>
#include <string.h>

#define PORT 8181

int main()
{
 int s , c;
 socklen_t addrlen;
 struct sockaddr_in srv , cli;

// initializing memory for server and client
 memset(&srv , 0 , sizeof(srv));
 memset(&cli , 0 , sizeof(cli));

// initializing socket server
 s = socket(AF_INET , SOCK_STREAM , 0);
 if( s < 0 ) { // handling error (should check after every system call)
  printf("socket()\n");
  return -1;
 }

 srv.sin_family = AF_INET;
 srv.sin_addr.s_addr = INADDR_ANY;// so that server listens on all IPs
 srv.sin_port = htons(PORT); // host to network short

 if(bind (s , (struct sockaddr *)&srv , sizeof(srv)))
 {
   printf("bind()\n);
   return -1;
 }
